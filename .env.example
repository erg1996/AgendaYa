# ─────────────────────────────────────────────────────────────────────────────
# AgendaYa — variables de entorno
# Copia este archivo como .env y completa los valores marcados como REQUIRED
# NUNCA subas .env a git
# ─────────────────────────────────────────────────────────────────────────────

# ── Seguridad (REQUIRED) ──────────────────────────────────────────────────────
# Mínimo 32 caracteres, string aleatorio. Generar con:
#   openssl rand -base64 48
JWT_SECRET=CAMBIA_ESTO_usa_openssl_rand_base64_48

# Email del primer super-admin (debe registrarse primero, luego reiniciar)
SUPER_ADMIN_EMAIL=tu@email.com

# ── Base de datos Supabase (REQUIRED) ─────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection pooling → Mode: Session
# IMPORTANTE: usar Session Pooler (puerto 5432), NO la conexión directa (IPv6 incompatible con Railway/IPv4)
# Agregar ?sslmode=require al final
DATABASE_URL=postgresql://postgres.deistvvsagsibqkrzifr:[TU_PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require

# ── URLs (REQUIRED) ───────────────────────────────────────────────────────────
# El origen desde donde se sirve el frontend (sin slash al final)
FRONTEND_ORIGIN=https://tudominio.com

# URL base usada en los links de confirmación de email (sin slash al final)
PUBLIC_URL=https://tudominio.com

# ── SMTP — envío de emails (opcional) ────────────────────────────────────────
# Si se deja vacío, los emails de confirmación se omiten silenciosamente.
#
# Ejemplo con Resend (recomendado):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxx
#   SMTP_FROM=AgendaYa <noreply@tudominio.com>
#
# Ejemplo con Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=tu@gmail.com
#   SMTP_PASS=contraseña-de-aplicación   (generar en myaccount.google.com/apppasswords)
#   SMTP_FROM=AgendaYa <tu@gmail.com>

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
